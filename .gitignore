# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (nunca subir secretos: Firebase, API keys, etc.)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# eslint
.eslintcache

# Firebase Admin / service account keys (si algún día usas backend con SDK Admin)
*-service-account*.json
firebase-adminsdk*.json
firebase-credentials*.json

# logs
*.log

# Archivos de datos sensibles (cuentas, cargas masivas, etc.)
*.csv
cuentas_municipales.csv

# Documentación (solo local, no subir al repo)
/docs

# Firebase: reglas y config (exponen estructura y lógica de seguridad)
firestore.rules
firebase.json
.firebaserc

# Datos operativos (plan anual, etc.) — no exponer en repo ni en public
public/projects-data.json
**/projects-data.json

# Backups, volcados y exports (pueden contener datos sensibles)
*.sql
*.dump
*.bak
*backup*
*-export*.json
